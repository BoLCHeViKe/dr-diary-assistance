# Copiar a .env y rellenar los valores reales antes de levantar Docker

# ─── Dominio público (online) ─────────────────────────────────────────────────
# Solo se usa con docker-compose _online.yml
# Pon aquí tu URL pública (sin barra final). El backend la usará como APP_URL.
DOMINIO=https://subdominio.dominio.org

# ─── Aplicación ──────────────────────────────────────────────────────────────
APP_NAME=DrDiaryAssistance
APP_KEY=                        # Generar con: docker compose exec backend php artisan key:generate --show

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_DATABASE=drdiaryassistance
DB_USERNAME=dda_user
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# ─── Puertos (host) — solo para docker-compose local/LAN ─────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=4200
MARIADB_PORT=3306
